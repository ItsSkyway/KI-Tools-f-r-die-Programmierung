<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>⚔️ Clash Royale - Enhanced Browser Game</title>
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; -webkit-font-smoothing: antialiased; overflow: hidden; background: linear-gradient(135deg, #0a0e27 0%, #1a0a2e 50%, #0f0420 100%); }
    #root { width: 100%; height: 100vh; display: flex; align-items: center; justify-content: center; }
    @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-15px); } }
    @keyframes pulse-glow { 0%, 100% { box-shadow: 0 0 20px rgba(255, 215, 0, 0.6); } 50% { box-shadow: 0 0 40px rgba(255, 215, 0, 1); } }
    @keyframes card-spawn { 0% { transform: scale(0.7) rotateY(90deg); opacity: 0; } 100% { transform: scale(1) rotateY(0deg); opacity: 1; } }
    @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }
    @keyframes victory-popup { 0% { transform: scale(0); opacity: 0; } 50% { transform: scale(1.1); } 100% { transform: scale(1); opacity: 1; } }
    @keyframes damage-pop { 0% { transform: scale(1) translateY(0); opacity: 1; } 100% { transform: scale(0.5) translateY(-40px); opacity: 0; } }
    @keyframes card-lift { 0% { transform: translateY(0); } 100% { transform: translateY(-12px); } }
    @keyframes drag-float { 0%, 100% { box-shadow: 0 15px 40px rgba(0, 0, 0, 0.8), 0 0 30px rgba(147, 51, 234, 0.6); } 50% { box-shadow: 0 20px 50px rgba(0, 0, 0, 0.9), 0 0 40px rgba(147, 51, 234, 0.8); } }
    @keyframes valid-glow { 0%, 100% { box-shadow: 0 0 20px rgba(34, 197, 94, 0.4), inset 0 0 20px rgba(34, 197, 94, 0.2); } 50% { box-shadow: 0 0 40px rgba(34, 197, 94, 0.6), inset 0 0 30px rgba(34, 197, 94, 0.3); } }
    @keyframes invalid-pulse { 0%, 100% { border-color: rgba(239, 68, 68, 0.8); box-shadow: 0 0 15px rgba(239, 68, 68, 0.4); } 50% { border-color: rgba(239, 68, 68, 1); box-shadow: 0 0 25px rgba(239, 68, 68, 0.6); } }
    @keyframes cycle-indicator { 0%, 100% { opacity: 0.6; transform: scale(1); } 50% { opacity: 1; transform: scale(1.1); } }
    .card-lift { animation: card-lift 0.3s ease-in-out; }
    .drag-float { animation: drag-float 0.6s ease-in-out infinite; }
    .valid-zone { animation: valid-glow 1s ease-in-out infinite; }
    .invalid-zone { animation: invalid-pulse 0.6s ease-in-out; }
    .cycle-pulse { animation: cycle-indicator 1.2s ease-in-out infinite; }
    .float { animation: float 3s ease-in-out infinite; }
    .pulse-glow { animation: pulse-glow 2s ease-in-out infinite; }
    .card-spawn { animation: card-spawn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .shake { animation: shake 0.3s ease-in-out; }
    .victory-popup { animation: victory-popup 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .damage-number { animation: damage-pop 1.5s ease-out forwards; }
    .card-lift { animation: card-lift 0.3s ease-in-out; }
    .drag-float { animation: drag-float 0.6s ease-in-out infinite; }
    .valid-zone { animation: valid-glow 1s ease-in-out infinite; }
    .invalid-zone { animation: invalid-pulse 0.6s ease-in-out; }
    .cycle-pulse { animation: cycle-indicator 1.2s ease-in-out infinite; }
    /* Dark Fantasy Theme - Enhanced Contrast */
    .rarity-common { background: linear-gradient(135deg, #6B4423 0%, #C9A961 100%); border-color: #E8D5B7; color: #FFF; text-shadow: 1px 1px 2px rgba(0,0,0,0.8); }
    .rarity-rare { background: linear-gradient(135deg, #1E5F9E 0%, #4A9FD8 100%); border-color: #6EB5E8; color: #FFF; text-shadow: 1px 1px 2px rgba(0,0,0,0.8); }
    .rarity-epic { background: linear-gradient(135deg, #6B2D7F 0%, #A855F7 100%); border-color: #D4AAFF; color: #FFF; text-shadow: 1px 1px 2px rgba(0,0,0,0.8); }
    .rarity-legendary { background: linear-gradient(135deg, #B8860B 0%, #FF8C00 100%); border-color: #FFB84D; color: #000; text-shadow: 1px 1px 2px rgba(255,255,255,0.4); box-shadow: 0 0 30px rgba(255, 165, 0, 0.9), inset 0 0 20px rgba(255, 215, 0, 0.3); }
    /* Card Hand Styles - 4-Card Layout */
    .hand-container {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      padding: 16px;
      background: linear-gradient(180deg, rgba(31, 41, 55, 0.95) 0%, rgba(17, 24, 39, 0.98) 100%);
      border-top: 3px solid rgba(147, 51, 234, 0.6);
      border-left: 2px solid #1f2937;
      border-right: 2px solid #1f2937;
      border-bottom: 2px solid #1f2937;
      border-radius: 12px 12px 0 0;
      backdrop-filter: blur(10px);
      min-height: 140px;
    }
    .hand-card {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 12px;
      border: 2px solid;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
      background: linear-gradient(135deg, rgba(55, 65, 81, 0.9) 0%, rgba(31, 41, 55, 0.95) 100%);
      user-select: none;
      overflow: visible;
      min-height: 100px;
    }
    .hand-card:hover:not(:disabled) {
      transform: translateY(-12px) scale(1.05);
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6), 0 0 20px rgba(147, 51, 234, 0.5);
    }
    .hand-card.dragging {
      opacity: 0.4;
      filter: grayscale(100%);
      cursor: grabbing;
    }
    .hand-card.can-play {
      cursor: grab;
    }
    .hand-card.cannot-play {
      opacity: 0.5;
      cursor: not-allowed;
      border-color: rgba(107, 114, 128, 0.5) !important;
    }
    .hand-card-emoji {
      font-size: 32px;
      line-height: 1;
      margin-bottom: 4px;
      display: block;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
    }
    .hand-card-name {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      line-height: 1.2;
      text-align: center;
      margin-bottom: 4px;
      color: #fff;
    }
    .hand-card-cost {
      font-size: 13px;
      font-weight: 800;
      color: #FCD34D;
      text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8);
      display: flex;
      align-items: center;
      gap: 2px;
    }
    .hand-card-rarity {
      position: absolute;
      top: 4px;
      right: 4px;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      border: 2px solid;
      font-size: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0.9;
    }
    .drag-ghost {
      position: fixed;
      pointer-events: none;
      z-index: 1000;
      opacity: 0.85;
    }
    .drop-zone {
      position: absolute;
      pointer-events: none;
      border: 3px dashed rgba(34, 197, 94, 0.3);
      border-radius: 8px;
      transition: all 0.2s ease;
    }
    .drop-zone.valid {
      border-color: rgba(34, 197, 94, 0.8);
      background: radial-gradient(circle at center, rgba(34, 197, 94, 0.1) 0%, transparent 70%);
      box-shadow: 0 0 30px rgba(34, 197, 94, 0.4), inset 0 0 20px rgba(34, 197, 94, 0.1);
    }
    .drop-zone.invalid {
      border-color: rgba(239, 68, 68, 0.6);
      background: radial-gradient(circle at center, rgba(239, 68, 68, 0.08) 0%, transparent 70%);
      box-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
    }
    .cycle-indicator {
      position: absolute;
      bottom: 8px;
      left: 8px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #3B82F6;
      border: 1px solid #93C5FD;
    }
    .cycle-indicator.active {
      background: #10B981;
      border-color: #6EE7B7;
      animation: cycle-pulse 1.2s ease-in-out infinite;
    }
    @media (max-width: 768px) {
      .hand-container {
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
        padding: 12px;
        min-height: 120px;
      }
      .hand-card {
        padding: 8px;
        min-height: 90px;
      }
      .hand-card-emoji {
        font-size: 24px;
      }
      .hand-card-name {
        font-size: 10px;
      }
      .hand-card-cost {
        font-size: 12px;
      }
    }
    @media (max-width: 480px) {
      .hand-container {
        grid-template-columns: repeat(4, 1fr);
        gap: 6px;
        padding: 8px;
        min-height: 100px;
      }
      .hand-card {
        padding: 6px;
        min-height: 80px;
      }
      .hand-card-emoji {
        font-size: 20px;
      }
      .hand-card-name {
        font-size: 9px;
      }
      .hand-card-cost {
        font-size: 11px;
      }
    }
    .tower-king { background: linear-gradient(to bottom, #FF6B6B 0%, #C92A2A 50%, #7A1D1D 100%); box-shadow: inset 0 2px 5px rgba(0,0,0,0.3), 0 5px 15px rgba(0,0,0,0.5); position: relative; }
    .tower-king::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 50%); }
    .tower-princess { background: linear-gradient(to bottom, #4169E1 0%, #1E90FF 50%, #0A3D8C 100%); box-shadow: inset 0 2px 5px rgba(0,0,0,0.3), 0 5px 15px rgba(0,0,0,0.5); }
    .tower-princess::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 50%); }
  </style>
</head>
<body>
  <div id="root"></div>
  <script type="text/babel">
const { useState, useEffect, useRef, useCallback } = React

// ============================================================================
// 🎵 AUDIO SYSTEM - Web Audio API Synth Tones
// ============================================================================
class AudioManager {
  constructor() {
    this.audioContext = null;
    this.masterVolume = 0.3;
    this.soundEnabled = true;
  }

  initAudio() {
    if (!this.audioContext) {
      this.audioContext = new (window.AudioContext || window.webkitAudioContext)();
    }
  }

  playTone(frequency, duration, type = 'sine', volume = 0.2) {
    if (!this.soundEnabled || !this.audioContext) return;
    
    const ctx = this.audioContext;
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    
    osc.type = type;
    osc.frequency.value = frequency;
    
    gain.gain.setValueAtTime(volume * this.masterVolume, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + duration);
    
    osc.connect(gain);
    gain.connect(ctx.destination);
    
    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + duration);
  }

  // Card grab sound - whoosh with sweep
  grabCard() {
    this.playTone(150, 0.08, 'sine', 0.15);
    setTimeout(() => this.playTone(300, 0.06, 'sine', 0.12), 20);
  }

  // Card placed successfully - uplifting chord
  placeCard() {
    this.playTone(523, 0.15, 'sine', 0.15);  // C
    setTimeout(() => this.playTone(659, 0.15, 'sine', 0.13), 40);  // E
    setTimeout(() => this.playTone(784, 0.18, 'sine', 0.12), 80);  // G
  }

  // Not enough elixir - sad beep
  errorBeep() {
    this.playTone(200, 0.12, 'sine', 0.2);
    setTimeout(() => this.playTone(150, 0.12, 'sine', 0.2), 100);
  }

  // Successful attack - quick bright tone
  successTone() {
    this.playTone(880, 0.08, 'sine', 0.15);
    setTimeout(() => this.playTone(1000, 0.1, 'sine', 0.12), 50);
  }

  // Unit death - descending tones
  deathSound() {
    this.playTone(400, 0.1, 'sine', 0.12);
    setTimeout(() => this.playTone(300, 0.1, 'sine', 0.12), 60);
    setTimeout(() => this.playTone(200, 0.15, 'sine', 0.1), 120);
  }

  // Victory fanfare - ascending arpeggio
  victoryFanfare() {
    const notes = [523, 659, 784, 1047];
    notes.forEach((freq, i) => {
      setTimeout(() => this.playTone(freq, 0.2, 'sine', 0.15), i * 100);
    });
  }

  // Defeat sound - descending sad tone
  defeatSound() {
    this.playTone(600, 0.15, 'sine', 0.15);
    setTimeout(() => this.playTone(400, 0.2, 'sine', 0.15), 150);
  }

  toggleSound() {
    this.soundEnabled = !this.soundEnabled;
  }
}

const audioManager = new AudioManager();

// ============================================================================
// 🎮 GAME CARDS & CONSTANTS
// ============================================================================
  knight: { id: 'knight', name: 'Knight', emoji: '🛡️', elixirCost: 3, rarity: 'common', type: 'troop', stats: { hp: 600, damage: 100, speed: 1, range: 50, attackSpeed: 1 } },
  archer: { id: 'archer', name: 'Archer', emoji: '🏹', elixirCost: 3, rarity: 'common', type: 'troop', stats: { hp: 200, damage: 120, speed: 1.2, range: 120, attackSpeed: 1.2 } },
  giant: { id: 'giant', name: 'Giant', emoji: '👹', elixirCost: 5, rarity: 'rare', type: 'troop', stats: { hp: 1800, damage: 60, speed: 0.7, range: 50, attackSpeed: 1.5, targetBuildings: true } },
  fireball: { id: 'fireball', name: 'Fireball', emoji: '🔥', elixirCost: 4, rarity: 'rare', type: 'spell', stats: { damage: 400, splashRadius: 120 } },
  arrows: { id: 'arrows', name: 'Arrows', emoji: '⬆️', elixirCost: 3, rarity: 'common', type: 'spell', stats: { damage: 200, splashRadius: 150 } },
  minions: { id: 'minions', name: 'Minions', emoji: '👿', elixirCost: 3, rarity: 'common', type: 'troop', stats: { hp: 100, damage: 80, speed: 1.4, range: 100, attackSpeed: 1, flying: true, count: 3 } },
  skeletonArmy: { id: 'skeletonArmy', name: 'Skeleton Army', emoji: '💀', elixirCost: 2, rarity: 'rare', type: 'troop', stats: { hp: 60, damage: 40, speed: 1.3, range: 40, attackSpeed: 0.8, count: 12 } },
  babyDragon: { id: 'babyDragon', name: 'Baby Dragon', emoji: '🐉', elixirCost: 4, rarity: 'rare', type: 'troop', stats: { hp: 800, damage: 120, speed: 0.9, range: 100, attackSpeed: 1.2, flying: true, splashRadius: 80 } },
  valkyrie: { id: 'valkyrie', name: 'Valkyrie', emoji: '⚔️', elixirCost: 4, rarity: 'rare', type: 'troop', stats: { hp: 900, damage: 130, speed: 0.9, range: 50, attackSpeed: 1.3, splashRadius: 100 } },
  musketeer: { id: 'musketeer', name: 'Musketeer', emoji: '🤠', elixirCost: 4, rarity: 'rare', type: 'troop', stats: { hp: 400, damage: 160, speed: 0.95, range: 140, attackSpeed: 1 } },
  hogRider: { id: 'hogRider', name: 'Hog Rider', emoji: '🐗', elixirCost: 4, rarity: 'epic', type: 'troop', stats: { hp: 500, damage: 150, speed: 1.5, range: 50, attackSpeed: 1.2, targetBuildings: true } },
  witch: { id: 'witch', name: 'Witch', emoji: '🧙‍♀️', elixirCost: 5, rarity: 'epic', type: 'troop', stats: { hp: 500, damage: 100, speed: 0.85, range: 100, attackSpeed: 1.2 } },
  pekka: { id: 'pekka', name: 'P.E.K.K.A', emoji: '🤖', elixirCost: 7, rarity: 'legendary', type: 'troop', stats: { hp: 2000, damage: 300, speed: 0.6, range: 60, attackSpeed: 1.8 } },
  bombTower: { id: 'bombTower', name: 'Bomb Tower', emoji: '💣', elixirCost: 5, rarity: 'rare', type: 'building', stats: { hp: 700, damage: 200, range: 130, attackSpeed: 1.2, splashRadius: 100 } },
  cannon: { id: 'cannon', name: 'Cannon', emoji: '🔫', elixirCost: 3, rarity: 'common', type: 'building', stats: { hp: 400, damage: 150, range: 100, attackSpeed: 1 } },
  freeze: { id: 'freeze', name: 'Freeze Spell', emoji: '❄️', elixirCost: 4, rarity: 'epic', type: 'spell', stats: { splashRadius: 120, freezeDuration: 2000 } },
}

const CARD_ARRAY = Object.values(CARDS)
const ARENA_WIDTH = 600
const ARENA_HEIGHT = 800
const LANE_WIDTH = ARENA_WIDTH / 2
const INITIAL_TOWER_HP = { king: 3500, princess: 1800 }

const findNearestEnemy = (unit, enemies, towers) => {
  let nearest = null, minDist = Infinity
  const range = unit.stats.range || 100
  if (unit.stats.targetBuildings && enemies.buildings) {
    enemies.buildings.forEach(b => {
      const dist = Math.hypot(b.x - unit.x, b.y - unit.y)
      if (dist < range && dist < minDist) { nearest = b; minDist = dist; }
    })
  }
  if (unit.stats.targetBuildings && towers) {
    towers.forEach(t => {
      if (t.hp > 0) {
        const dist = Math.hypot(t.x - unit.x, t.y - unit.y)
        if (dist < range && dist < minDist) { nearest = t; minDist = dist; }
      }
    })
  }
  if (enemies.troops) {
    enemies.troops.forEach(t => {
      if (t.hp > 0) {
        const dist = Math.hypot(t.x - unit.x, t.y - unit.y)
        if (dist < range && dist < minDist) { nearest = t; minDist = dist; }
      }
    })
  }
  return nearest
}

const moveUnit = (unit, targetX, targetY, speed = 1) => {
  const dist = Math.hypot(targetX - unit.x, targetY - unit.y)
  if (dist < speed) { unit.x = targetX; unit.y = targetY; return true }
  const ratio = speed / dist
  unit.x += (targetX - unit.x) * ratio
  unit.y += (targetY - unit.y) * ratio
  return false
}

const victoryMessages = ['🎉 Tremendous Victory!', '👑 You are the Champion!', '⚔️ Glorious Battle Won!', '🏆 Legendary Clash!', '💪 Absolutely Dominant!']
const defeatMessages = ['💭 Close Battle! Try Again!', '🎯 Good Attempt! Try Again!', '🔄 Learn & Adapt!', '💪 Keep Practicing!', '🎮 Battle Lost, War Not Over!']

function ClashRoyaleGame() {
  const [screen, setScreen] = useState('menu')
  const [difficulty, setDifficulty] = useState('medium')
  const [selectedDeck, setSelectedDeck] = useState([])
  const [damageNumbers, setDamageNumbers] = useState([])

  const gameStateRef = useRef({
    playerElixir: 10, enemyElixir: 10, timeRemaining: 180, gameOver: false, winner: null,
    playerTroops: [], playerBuildings: [], enemyTroops: [], enemyBuildings: [],
    playerHand: [], enemyHand: [], lastCardPlayTime: { player: 0, enemy: 0 }, freezeZones: [], destroyedTowers: [], phase: 'early',
  })

  const towerStateRef = useRef({
    player: {
      kingTower: { x: ARENA_WIDTH / 2, y: ARENA_HEIGHT - 60, hp: INITIAL_TOWER_HP.king, isKing: true },
      princessLeft: { x: LANE_WIDTH / 2 - 80, y: ARENA_HEIGHT - 120, hp: INITIAL_TOWER_HP.princess },
      princessRight: { x: LANE_WIDTH / 2 + 80, y: ARENA_HEIGHT - 120, hp: INITIAL_TOWER_HP.princess },
    },
    enemy: {
      kingTower: { x: ARENA_WIDTH / 2, y: 60, hp: INITIAL_TOWER_HP.king, isKing: true },
      princessLeft: { x: LANE_WIDTH / 2 - 80, y: 120, hp: INITIAL_TOWER_HP.princess },
      princessRight: { x: LANE_WIDTH / 2 + 80, y: 120, hp: INITIAL_TOWER_HP.princess },
    },
  })

  const [uiState, setUiState] = useState(0)
  const [gameStats, setGameStats] = useState({
    playerHPBars: [], playerBuildingBars: [], enemyHPBars: [], enemyBuildingBars: [],
    playerElixir: 10, enemyElixir: 10, gameTime: 180, towers: {},
  })

  // Drag-and-drop state
  const [dragState, setDragState] = useState({
    isDragging: false,
    draggedCardId: null,
    cursorX: 0,
    cursorY: 0,
    draggedCard: null,
  })

  const handleCardMouseDown = useCallback((e, handItem) => {
    const card = CARDS[handItem.cardId]
    const gs = gameStateRef.current
    const canPlay = gameStats.playerElixir >= card.elixirCost && !gs.gameOver
    
    if (!canPlay || e.button !== 0) return
    
    setDragState({
      dragging: handItem.id,
      ghostCard: card,
      ghostPos: { x: e.clientX, y: e.clientY },
      dropZoneValid: null,
    })
  }, [gameStats.playerElixir])

  const handleCardDragStart = useCallback((e, handItem, card) => {
    const gs = gameStateRef.current
    const canPlay = gameStats.playerElixir >= card.elixirCost && !gs.gameOver
    
    if (!canPlay) {
      e.preventDefault()
      return
    }
    
    setDragState({
      dragging: handItem.id,
      ghostCard: card,
      ghostPos: { x: e.clientX, y: e.clientY },
      dropZoneValid: null,
    })
    
    // Custom drag image
    const dragImage = new Image()
    dragImage.src = 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="90" height="100"><rect width="90" height="100" fill="rgba(55,65,81,0.95)" rx="10" stroke="rgba(147,51,234,0.8)" stroke-width="2"/><text x="45" y="40" font-size="28" text-anchor="middle" dominant-baseline="middle">' + card.emoji + '</text></svg>'
    e.dataTransfer.setDragImage(dragImage, 45, 50)
    e.dataTransfer.effectAllowed = 'copy'
  }, [gameStats.playerElixir])

  const handleCardDragEnd = useCallback((e) => {
    setDragState(prev => ({
      ...prev,
      dragging: null,
      ghostCard: null,
      dropZoneValid: null,
    }))
  }, [])

  const handleMouseMove = useCallback((e) => {
    if (!dragState.dragging) return
    
    setDragState(prev => ({
      ...prev,
      ghostPos: { x: e.clientX, y: e.clientY },
    }))
    
    // Check if over valid drop zone (arena)
    const arenaElement = document.querySelector('.arena-container')
    if (arenaElement) {
      const rect = arenaElement.getBoundingClientRect()
      const isOverArena = e.clientX >= rect.left && e.clientX <= rect.right &&
                          e.clientY >= rect.top && e.clientY <= rect.bottom
      
      setDragState(prev => ({
        ...prev,
        dropZoneValid: isOverArena ? 'valid' : 'invalid',
      }))
    }
  }, [dragState.dragging])

  const handleMouseUp = useCallback((e) => {
    if (!dragState.dragging || !dragState.ghostCard) return
    
    const arenaElement = document.querySelector('.arena-container')
    if (arenaElement) {
      const arenaRect = arenaElement.getBoundingClientRect()
      const relativeX = e.clientX - arenaRect.left
      const relativeY = e.clientY - arenaRect.top
      
      // Check if drop is within arena bounds and in player's half
      if (relativeX >= 0 && relativeX <= ARENA_WIDTH && relativeY >= ARENA_HEIGHT / 2 && relativeY <= ARENA_HEIGHT) {
        playCard(dragState.ghostCard.id, true, relativeX, relativeY)
      }
    }
    
    setDragState({ dragging: null, ghostPos: { x: 0, y: 0 }, dropZoneValid: null, ghostCard: null })
  }, [dragState.dragging, dragState.ghostCard, playCard])
    
    const gs = gameStateRef.current
    
    // Get arena position
    const arenaElement = document.getElementById('game-arena')
    if (!arenaElement) {
      setDragState({ isDragging: false, draggedCardId: null, cursorX: 0, cursorY: 0, draggedCard: null })
      return
    }
    
    const arenaRect = arenaElement.getBoundingClientRect()
    const relativeX = e.clientX - arenaRect.left
    const relativeY = e.clientY - arenaRect.top
    
    // Check if drop is within arena bounds
    if (relativeX >= 0 && relativeX <= ARENA_WIDTH && relativeY >= 0 && relativeY <= ARENA_HEIGHT) {
      // Only allow placement in player's half (bottom half)
      if (relativeY >= ARENA_HEIGHT / 2) {
        playCard(dragState.draggedCard.cardId, true, relativeX, relativeY)
      }
    }
    
    setDragState({ isDragging: false, draggedCardId: null, cursorX: 0, cursorY: 0, draggedCard: null })
  }, [dragState.isDragging, dragState.draggedCard, playCard])

  // Attach mouse listeners
  useEffect(() => {
    if (screen !== 'battle') return
    
    window.addEventListener('mousemove', handleMouseMove)
    window.addEventListener('mouseup', handleMouseUp)
    
    return () => {
      window.removeEventListener('mousemove', handleMouseMove)
      window.removeEventListener('mouseup', handleMouseUp)
    }
  }, [screen, handleMouseMove, handleMouseUp])

  // ============================================================================
  // 🎴 DECK CYCLING SYSTEM - Utility Functions
  // ============================================================================
  
  // Fisher-Yates shuffle for true randomization
  const shuffleDeck = (deck) => {
    const shuffled = [...deck]
    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]]
    }
    return shuffled
  }

  // Draw cards from pool, reshuffle if needed
  const drawCardsFromPool = (pool, count) => {
    const drawn = []
    for (let i = 0; i < count; i++) {
      if (pool.length === 0) {
        // Reshuffle entire deck
        const fullDeck = (pool.fullDeck || [])
        const reshuffled = shuffleDeck(fullDeck)
        pool.splice(0, pool.length, ...reshuffled) // Clear and refill pool
        pool.cycleCount = (pool.cycleCount || 0) + 1
      }
      if (pool.length > 0) {
        drawn.push(pool.shift())
      }
    }
    return drawn
  }

  const playCard = useCallback((cardId, isPlayer = true, spawnX = null, spawnY = null) => {
    const gs = gameStateRef.current
    const card = CARDS[cardId]
    if (!card) return

    const elixir = isPlayer ? gs.playerElixir : gs.enemyElixir
    if (elixir < card.elixirCost) return

    if (isPlayer) gs.playerElixir -= card.elixirCost
    else gs.enemyElixir -= card.elixirCost

    const hand = isPlayer ? gs.playerHand : gs.enemyHand
    const handIdx = hand.findIndex(h => h.cardId === cardId)
    if (handIdx >= 0) hand.splice(handIdx, 1)

    if (card.type === 'spell') {
      const side = isPlayer ? 'enemy' : 'player'
      const targetTroops = side === 'enemy' ? gs.enemyTroops : gs.playerTroops
      const targetBuildings = side === 'enemy' ? gs.enemyBuildings : gs.playerBuildings

      if (cardId === 'fireball') {
        const centerX = spawnX || (isPlayer ? ARENA_WIDTH * 0.75 : ARENA_WIDTH * 0.25)
        const centerY = spawnY || (isPlayer ? ARENA_HEIGHT * 0.3 : ARENA_HEIGHT * 0.7)
        targetTroops.forEach(t => {
          const dist = Math.hypot(t.x - centerX, t.y - centerY)
          if (dist < 120) { t.hp -= 400; setDamageNumbers(prev => [...prev, { x: t.x, y: t.y, damage: 400 }]) }
        })
        targetBuildings.forEach(b => {
          const dist = Math.hypot(b.x - centerX, b.y - centerY)
          if (dist < 120) b.hp -= 400
        })
      } else if (cardId === 'arrows') {
        const centerX = spawnX || (isPlayer ? ARENA_WIDTH * 0.75 : ARENA_WIDTH * 0.25)
        const centerY = spawnY || (isPlayer ? ARENA_HEIGHT * 0.3 : ARENA_HEIGHT * 0.7)
        targetTroops.forEach(t => {
          const dist = Math.hypot(t.x - centerX, t.y - centerY)
          if (dist < 150) { t.hp -= 200; setDamageNumbers(prev => [...prev, { x: t.x, y: t.y, damage: 200 }]) }
        })
      } else if (cardId === 'freeze') {
        const centerX = spawnX || (isPlayer ? ARENA_WIDTH * 0.75 : ARENA_WIDTH * 0.25)
        const centerY = spawnY || (isPlayer ? ARENA_HEIGHT * 0.3 : ARENA_HEIGHT * 0.7)
        targetTroops.forEach(t => {
          const dist = Math.hypot(t.x - centerX, t.y - centerY)
          if (dist < 120) t.frozen = 2000
        })
      }
    } else {
      const troops = isPlayer ? gs.playerTroops : gs.enemyTroops
      const buildings = isPlayer ? gs.playerBuildings : gs.enemyBuildings
      
      // Use provided spawn position or fallback to default
      const defaultSpawnX = isPlayer ? LANE_WIDTH / 2 : LANE_WIDTH + LANE_WIDTH / 2
      const defaultSpawnY = isPlayer ? ARENA_HEIGHT - 200 : 200
      const finalSpawnX = spawnX !== null ? spawnX : defaultSpawnX
      const finalSpawnY = spawnY !== null ? spawnY : defaultSpawnY

      if (card.type === 'building') {
        buildings.push({ id: Math.random(), cardId, card, x: finalSpawnX, y: finalSpawnY, hp: card.stats.hp, lastAttackTime: 0, isPlayer })
      } else {
        const count = card.stats.count || 1
        for (let i = 0; i < count; i++) {
          troops.push({ id: Math.random(), cardId, card, x: finalSpawnX + (Math.random() - 0.5) * 30, y: finalSpawnY + (Math.random() - 0.5) * 30, hp: card.stats.hp, lastAttackTime: 0, isPlayer })
        }
      }
    }

    // ========== NEW: Draw replacement card from deck pool ==========
    const deckPool = isPlayer ? gs.playerDeckPool : gs.enemyDeckPool
    const drawnCards = drawCardsFromPool(deckPool, 1)
    if (drawnCards.length > 0) {
      const newCardId = drawnCards[0]
      hand.push({ cardId: newCardId, id: Math.random() })
    }
    // Hand should always be 4 cards now
  }, [])

  const botPlayCard = useCallback(() => {
    const gs = gameStateRef.current
    if (gs.gameOver) return

    const now = Date.now()
    const hand = gs.enemyHand
    if (hand.length === 0) return

    let playInterval = 5000
    if (difficulty === 'medium') playInterval = 4000
    if (difficulty === 'hard') playInterval = 2500

    if (now - gs.lastCardPlayTime.enemy < playInterval) return

    const playableCards = hand.filter(h => gs.enemyElixir >= CARDS[h.cardId].elixirCost)
    if (playableCards.length === 0) return

    let selectedCard = playableCards[0]
    if (difficulty === 'hard') {
      const highValue = playableCards.filter(h => CARDS[h.cardId].elixirCost >= 4)
      if (highValue.length > 0 && gs.enemyElixir >= 8) {
        selectedCard = highValue[Math.floor(Math.random() * highValue.length)]
      }
    }

    playCard(selectedCard.cardId, false)
    gs.lastCardPlayTime.enemy = now
  }, [difficulty, playCard])

  const initializeGame = useCallback(() => {
    const gs = gameStateRef.current
    gs.playerElixir = 10
    gs.enemyElixir = 10
    gs.gameTime = 180000  // 180 seconds in milliseconds
    gs.timeRemaining = 180  // Track seconds for display
    gs.gameOver = false
    gs.winner = null
    gs.playerTroops = []
    gs.playerBuildings = []
    gs.enemyTroops = []
    gs.enemyBuildings = []
    
    // ========== NEW: Deck Cycling System ==========
    // Initialize player deck pool
    const playerDeckFull = [...selectedDeck]
    const playerDeckPoolShuffled = shuffleDeck(playerDeckFull)
    gs.playerDeckPool = playerDeckPoolShuffled
    gs.playerDeckPool.fullDeck = playerDeckFull // Store original for reshuffling
    gs.playerDeckPool.cycleCount = 0
    
    // Draw initial 4 cards for player
    const playerInitialHand = drawCardsFromPool(gs.playerDeckPool, 4)
    gs.playerHand = playerInitialHand.map(cardId => ({ cardId, id: Math.random() }))
    
    // Initialize enemy deck pool (use first 8 cards, shuffled)
    const enemyDeckFull = CARD_ARRAY.slice(0, 8).map(c => c.id)
    const enemyDeckPoolShuffled = shuffleDeck(enemyDeckFull)
    gs.enemyDeckPool = enemyDeckPoolShuffled
    gs.enemyDeckPool.fullDeck = enemyDeckFull
    gs.enemyDeckPool.cycleCount = 0
    
    // Draw initial 4 cards for enemy
    const enemyInitialHand = drawCardsFromPool(gs.enemyDeckPool, 4)
    gs.enemyHand = enemyInitialHand.map(cardId => ({ cardId, id: Math.random() }))
    
    gs.lastCardPlayTime = { player: 0, enemy: 0 }
    gs.freezeZones = []
    gs.destroyedTowers = []
    gs.phase = 'early'
  }, [selectedDeck])

  useEffect(() => {
    if (screen !== 'battle') return

    let frameCount = 0
    const gameLoopInterval = setInterval(() => {
      const gs = gameStateRef.current
      const towers = towerStateRef.current

      if (gs.gameOver) return

      frameCount++
      // TIMER FIX: Decrement by 1 second every 30 frames (interval is 33ms, so ~30 frames = 1 second)
      if (frameCount >= 30) {
        gs.timeRemaining -= 1
        frameCount = 0
        
        if (gs.timeRemaining <= 0) {
          gs.timeRemaining = 0
          gs.gameOver = true
          const playerTowerHp = Object.values(towers.player).reduce((sum, t) => sum + t.hp, 0)
          const enemyTowerHp = Object.values(towers.enemy).reduce((sum, t) => sum + t.hp, 0)
          gs.winner = enemyTowerHp < playerTowerHp ? 'player' : enemyTowerHp > playerTowerHp ? 'enemy' : 'tie'
        }
      }

      if (gs.timeRemaining > 120) gs.phase = 'early'
      else if (gs.timeRemaining > 60) gs.phase = 'mid'
      else gs.phase = 'late'

      const elixirRegenRate = gs.phase === 'early' ? 0.015 : gs.phase === 'mid' ? 0.03 : 0.045
      gs.playerElixir = Math.min(10, gs.playerElixir + elixirRegenRate)
      gs.enemyElixir = Math.min(10, gs.enemyElixir + elixirRegenRate)

      gs.playerTroops = gs.playerTroops.filter(u => u.hp > 0)
      gs.enemyTroops = gs.enemyTroops.filter(u => u.hp > 0)
      gs.playerBuildings = gs.playerBuildings.filter(u => u.hp > 0)
      gs.enemyBuildings = gs.enemyBuildings.filter(u => u.hp > 0)

      gs.playerTroops.forEach(u => { if (u.frozen) u.frozen -= 33 })
      gs.enemyTroops.forEach(u => { if (u.frozen) u.frozen -= 33 })

      ;[
        { units: gs.playerTroops, enemies: { troops: gs.enemyTroops, buildings: gs.enemyBuildings }, enemyTowers: towers.enemy },
        { units: gs.enemyTroops, enemies: { troops: gs.playerTroops, buildings: gs.playerBuildings }, enemyTowers: towers.player },
      ].forEach(({ units, enemies, enemyTowers }) => {
        units.forEach(unit => {
          if (unit.frozen && unit.frozen > 0) return

          const target = findNearestEnemy(unit, enemies, Object.values(enemyTowers))
          if (target) {
            const dist = Math.hypot(target.x - unit.x, target.y - unit.y)
            const range = unit.card.stats.range || 100

            if (dist < range) {
              const now = Date.now()
              const attackSpeed = unit.card.stats.attackSpeed || 1
              if (now - unit.lastAttackTime > 1000 / attackSpeed) {
                const damage = unit.card.stats.damage || 50
                target.hp -= damage
                unit.lastAttackTime = now
              }
            } else {
              const speed = unit.card.stats.speed || 1
              moveUnit(unit, target.x, target.y, speed)
            }
          } else {
            const targetY = unit.isPlayer ? 0 : ARENA_HEIGHT
            const speed = unit.card.stats.speed || 1
            moveUnit(unit, unit.x, targetY, speed * 0.5)
          }
        })
      })

      ;[
        { buildings: gs.playerBuildings, enemies: { troops: gs.enemyTroops }, towers: towers.enemy },
        { buildings: gs.enemyBuildings, enemies: { troops: gs.playerTroops }, towers: towers.player },
      ].forEach(({ buildings, enemies, towers: enemyTowers }) => {
        buildings.forEach(building => {
          const targets = enemies.troops.filter(t => t.hp > 0)
          const range = building.card.stats.range || 100

          const nearest = targets.length > 0
            ? targets.reduce((closest, t) => {
                const d = Math.hypot(t.x - building.x, t.y - building.y)
                const dc = Math.hypot(closest.x - building.x, closest.y - building.y)
                return d < dc ? t : closest
              })
            : null

          if (nearest && Math.hypot(nearest.x - building.x, nearest.y - building.y) < range) {
            const now = Date.now()
            if (now - building.lastAttackTime > 1000 / (building.card.stats.attackSpeed || 1)) {
              const damage = building.card.stats.damage || 50
              nearest.hp -= damage
              if (building.card.stats.splashRadius) {
                targets.forEach(t => {
                  if (Math.hypot(t.x - nearest.x, t.y - nearest.y) < building.card.stats.splashRadius) {
                    t.hp -= damage * 0.6
                  }
                })
              }
              building.lastAttackTime = now
            }
          }
        })
      })

      const towerAttack = (tower, troops) => {
        if (tower.hp <= 0) return
        const range = 150
        const targets = troops.filter(t => Math.hypot(t.x - tower.x, t.y - tower.y) < range && t.hp > 0)
        if (targets.length > 0) {
          const target = targets[0]
          const now = Date.now()
          if (now - tower.lastAttackTime > 1000) {
            target.hp -= 150
            tower.lastAttackTime = now
          }
        }
      }

      Object.values(towers.player).forEach(tower => towerAttack(tower, gs.enemyTroops))
      Object.values(towers.enemy).forEach(tower => towerAttack(tower, gs.playerTroops))

      if (towers.player.kingTower.hp <= 0) { gs.gameOver = true; gs.winner = 'enemy' }
      if (towers.enemy.kingTower.hp <= 0) { gs.gameOver = true; gs.winner = 'player' }

      botPlayCard()

      setGameStats({
        playerElixir: Math.floor(gs.playerElixir * 10) / 10,
        enemyElixir: Math.floor(gs.enemyElixir * 10) / 10,
        gameTime: Math.max(0, gs.timeRemaining),
        towers: {
          playerKing: towers.player.kingTower.hp,
          playerLeftPrincess: towers.player.princessLeft.hp,
          playerRightPrincess: towers.player.princessRight.hp,
          enemyKing: towers.enemy.kingTower.hp,
          enemyLeftPrincess: towers.enemy.princessLeft.hp,
          enemyRightPrincess: towers.enemy.princessRight.hp,
        },
        playerHPBars: gs.playerTroops.map(u => ({ id: u.id, hp: u.hp, maxHp: u.card.stats.hp, x: u.x, y: u.y })),
        playerBuildingBars: gs.playerBuildings.map(b => ({ id: b.id, hp: b.hp, maxHp: b.card.stats.hp, x: b.x, y: b.y })),
        enemyHPBars: gs.enemyTroops.map(u => ({ id: u.id, hp: u.hp, maxHp: u.card.stats.hp, x: u.x, y: u.y })),
        enemyBuildingBars: gs.enemyBuildings.map(b => ({ id: b.id, hp: b.hp, maxHp: b.card.stats.hp, x: b.x, y: b.y })),
      })

      setUiState(prev => prev + 1)
    }, 33)

    return () => clearInterval(gameLoopInterval)
  }, [screen, botPlayCard])

  const renderArena = () => {
    const gs = gameStateRef.current
    const towers = towerStateRef.current

    return (
      <div id="game-arena" className="arena-container relative bg-gradient-to-b from-red-900 to-red-950 border-4 border-yellow-600 shadow-2xl" style={{ width: ARENA_WIDTH, height: ARENA_HEIGHT }}>
        {/* Drop zone highlight during drag - Valid Zone */}
        {dragState.dragging && dragState.dropZoneValid === 'valid' && (
          <div className="absolute inset-0 pointer-events-none valid-zone" style={{
            background: 'radial-gradient(ellipse at center bottom, rgba(34, 197, 94, 0.2) 0%, transparent 70%)',
          }} />
        )}
        
        {/* Drop zone highlight during drag - Invalid Zone */}
        {dragState.dragging && dragState.dropZoneValid === 'invalid' && (
          <div className="absolute inset-0 pointer-events-none invalid-zone" style={{
            background: 'radial-gradient(ellipse at center bottom, rgba(239, 68, 68, 0.15) 0%, transparent 70%)',
          }} />
        )}
        
        <div className="absolute w-full h-px bg-yellow-600" style={{ top: ARENA_HEIGHT / 2 }} />

        <div className="absolute tower-king" style={{ left: towers.enemy.kingTower.x - 16, top: towers.enemy.kingTower.y - 20, width: 32, height: 40, borderRadius: 8 }}>
          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', height: '100%', fontSize: '24px' }}>👑</div>
        </div>
        <div className="absolute tower-princess" style={{ left: towers.enemy.princessLeft.x - 12, top: towers.enemy.princessLeft.y - 16, width: 24, height: 32, borderRadius: 6 }}>🏰</div>
        <div className="absolute tower-princess" style={{ left: towers.enemy.princessRight.x - 12, top: towers.enemy.princessRight.y - 16, width: 24, height: 32, borderRadius: 6 }}>🏰</div>

        <div className="absolute tower-king" style={{ left: towers.player.kingTower.x - 16, top: towers.player.kingTower.y - 20, width: 32, height: 40, borderRadius: 8 }}>
          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', height: '100%', fontSize: '24px' }}>👑</div>
        </div>
        <div className="absolute tower-princess" style={{ left: towers.player.princessLeft.x - 12, top: towers.player.princessLeft.y - 16, width: 24, height: 32, borderRadius: 6 }}>🏰</div>
        <div className="absolute tower-princess" style={{ left: towers.player.princessRight.x - 12, top: towers.player.princessRight.y - 16, width: 24, height: 32, borderRadius: 6 }}>🏰</div>

        {gs.enemyTroops.map(unit => <div key={unit.id} className="absolute w-6 h-6 bg-red-500 rounded-full border border-yellow-300 flex items-center justify-center text-xs font-bold shadow-lg" style={{ left: unit.x - 12, top: unit.y - 12 }}>{unit.card.emoji}</div>)}
        {gs.playerTroops.map(unit => <div key={unit.id} className="absolute w-6 h-6 bg-blue-500 rounded-full border border-yellow-300 flex items-center justify-center text-xs font-bold shadow-lg card-spawn" style={{ left: unit.x - 12, top: unit.y - 12 }}>{unit.card.emoji}</div>)}

        {gameStats.playerHPBars.map(bar => <div key={`hp-${bar.id}`} className="absolute w-10 h-1 bg-red-900 rounded" style={{ left: bar.x - 20, top: bar.y - 20 }}><div className="h-full bg-green-500 rounded transition-all" style={{ width: `${Math.max(0, (bar.hp / bar.maxHp) * 100)}%` }} /></div>)}
        {gameStats.enemyHPBars.map(bar => <div key={`hp-${bar.id}`} className="absolute w-10 h-1 bg-red-900 rounded" style={{ left: bar.x - 20, top: bar.y - 20 }}><div className="h-full bg-green-500 rounded transition-all" style={{ width: `${Math.max(0, (bar.hp / bar.maxHp) * 100)}%` }} /></div>)}

        {damageNumbers.map((dmg, i) => <div key={i} className="absolute text-red-500 font-bold damage-number" style={{ left: dmg.x, top: dmg.y }}>-{dmg.damage}</div>)}

        {/* Drag ghost - follows cursor */}
        {dragState.isDragging && dragState.draggedCard && (
          <div className="absolute pointer-events-none" style={{
            left: dragState.cursorX - ARENA_WIDTH / 2 - 30,
            top: dragState.cursorY - 60,
            opacity: 0.7,
            zIndex: 1000,
          }}>
            <div className="p-2 rounded border-2 border-yellow-400 bg-blue-600 w-16 text-center">
              <div className="text-2xl">{CARDS[dragState.draggedCard.cardId].emoji}</div>
              <div className="text-xs font-bold text-white">{CARDS[dragState.draggedCard.cardId].elixirCost}⚡</div>
            </div>
          </div>
        )}
      </div>
    )
  }

  const renderUI = () => {
    const gs = gameStateRef.current
    const towers = towerStateRef.current

    return (
      <div className="w-full max-w-2xl">
        <div className="flex justify-between items-center bg-gray-900 text-white p-3 rounded-t border-2 border-yellow-600">
          <div className="flex gap-4">
            <div className="flex gap-2 items-center"><span className="text-lg">❤️</span><span className="text-sm font-bold">{Math.max(0, Math.floor(towers.enemy.kingTower.hp))}</span></div>
            <div className="flex gap-2 items-center"><span className="text-lg">🏰</span><span className="text-sm font-bold">{Math.max(0, Math.floor(towers.enemy.princessLeft.hp))}</span></div>
            <div className="flex gap-2 items-center"><span className="text-lg">🏰</span><span className="text-sm font-bold">{Math.max(0, Math.floor(towers.enemy.princessRight.hp))}</span></div>
          </div>
          <div className={`text-2xl font-bold ${gameStats.gameTime < 60 ? 'text-red-400 pulse-glow' : 'text-yellow-400'}`}>{gameStats.gameTime}s</div>
          <div className="flex gap-4">
            <div className="flex gap-2 items-center"><span className="text-lg">❤️</span><span className="text-sm font-bold">{Math.max(0, Math.floor(towers.player.kingTower.hp))}</span></div>
            <div className="flex gap-2 items-center"><span className="text-lg">🏰</span><span className="text-sm font-bold">{Math.max(0, Math.floor(towers.player.princessLeft.hp))}</span></div>
            <div className="flex gap-2 items-center"><span className="text-lg">🏰</span><span className="text-sm font-bold">{Math.max(0, Math.floor(towers.player.princessRight.hp))}</span></div>
          </div>
        </div>

        <div className="flex justify-center">{renderArena()}</div>

        <div className="bg-gray-900 text-white p-3 flex items-center gap-2 border-x-2 border-yellow-600">
          <span className="text-sm font-bold w-12">Elixir</span>
          <div className="flex-1 bg-gray-800 rounded h-6 border-2 border-purple-500 relative overflow-hidden">
            <div className="h-full bg-gradient-to-r from-purple-600 to-purple-400 transition-all" style={{ width: `${(gameStats.playerElixir / 10) * 100}%` }} />
            <span className="absolute inset-0 flex items-center justify-center text-white text-xs font-bold">{Math.floor(gameStats.playerElixir)}/10</span>
          </div>
        </div>

        <div className="bg-gray-800 text-white p-3 border-2 border-yellow-600 rounded-b">
          <div className="grid grid-cols-4 gap-2">
            {gs.playerHand.map(handItem => {
              const card = CARDS[handItem.cardId]
              const canPlay = gameStats.playerElixir >= card.elixirCost && !gs.gameOver
              const isDragging = dragState.isDragging && dragState.draggedCardId === handItem.id
              return (
                <div
                  key={handItem.id}
                  onMouseDown={() => handleCardMouseDown(handItem)}
                  className={`p-2 rounded border-2 transition-all text-center card-spawn select-none ${
                    isDragging 
                      ? 'scale-95 opacity-60 cursor-grabbing' 
                      : canPlay 
                        ? `bg-gradient-to-b to-purple-800 border-yellow-400 hover:shadow-lg hover:scale-105 cursor-grab rarity-${card.rarity}` 
                        : 'bg-gray-700 border-gray-600 opacity-50 cursor-not-allowed'
                  }`}
                  style={{ userSelect: 'none' }}
                >
                  <div className="text-2xl">{card.emoji}</div>
                  <div className="text-xs font-bold">{card.name.slice(0, 8)}</div>
                  <div className="text-xs text-yellow-300 font-bold">{card.elixirCost}⚡</div>
                </div>
              )
            })}
          </div>
        </div>
      </div>
    )
  }

  if (screen === 'menu') {
    return (
      <div className="flex flex-col items-center justify-center min-h-screen text-white p-4">
        <div className="text-6xl font-bold mb-4 text-yellow-400 float">⚔️ Clash Royale</div>
        <div className="text-2xl mb-8 text-gray-300">Enhanced Browser Game</div>
        <div className="mb-6"><p className="text-lg mb-4">Select Difficulty:</p><div className="flex gap-4">
          {['easy', 'medium', 'hard'].map(diff => <button key={diff} onClick={() => setDifficulty(diff)} className={`px-6 py-3 rounded-lg font-bold transition-all ${difficulty === diff ? 'bg-yellow-500 text-black scale-110 pulse-glow' : 'bg-gray-700 text-white hover:bg-gray-600'}`}>{diff.toUpperCase()}</button>)}
        </div></div>
        <button onClick={() => { setSelectedDeck([]); setScreen('deckBuilder') }} className="px-8 py-4 bg-gradient-to-r from-green-500 to-green-600 text-white font-bold text-lg rounded-lg hover:shadow-lg hover:scale-105 transition-all">Build Deck</button>
      </div>
    )
  }

  if (screen === 'deckBuilder') {
    return (
      <div className="flex flex-col items-center justify-center min-h-screen bg-gradient-to-b from-gray-900 to-black text-white p-4 overflow-y-auto">
        <h1 className="text-4xl font-bold mb-2 text-yellow-400">Build Your Deck</h1>
        <p className="text-lg mb-6">Select exactly 8 cards (Current: {selectedDeck.length}/8)</p>
        <div className="mb-6 text-center"><p className="text-lg">Average Elixir: {selectedDeck.length > 0 ? (selectedDeck.reduce((sum, cardId) => sum + CARDS[cardId].elixirCost, 0) / selectedDeck.length).toFixed(1) : 0}</p></div>
        <div className="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6 max-w-4xl">
          {CARD_ARRAY.map(card => {
            const isSelected = selectedDeck.includes(card.id)
            return (
              <button key={card.id} onClick={() => { if (isSelected) setSelectedDeck(selectedDeck.filter((cid, idx) => !(cid === card.id && selectedDeck.indexOf(cid) === idx))); else if (selectedDeck.length < 8) setSelectedDeck([...selectedDeck, card.id]) }}
                className={`p-3 rounded-lg border-2 transition-all card-spawn ${isSelected ? `border-yellow-400 shadow-lg scale-105 rarity-${card.rarity}` : `border-gray-600 bg-gray-800 hover:border-gray-400 rarity-${card.rarity}`}`}>
                <div className="text-3xl mb-2">{card.emoji}</div>
                <div className="text-xs font-bold">{card.name}</div>
                <div className="text-xs text-yellow-300">{card.elixirCost}⚡</div>
                <div className="text-xs text-gray-400">{card.type}</div>
              </button>
            )
          })}
        </div>
        <div className="flex gap-4">
          <button onClick={() => { setSelectedDeck([]); setScreen('menu') }} className="px-6 py-3 bg-gray-700 text-white font-bold rounded-lg hover:bg-gray-600 transition-all">Back</button>
          <button onClick={() => { if (selectedDeck.length === 8) { initializeGame(); setScreen('battle') } }} disabled={selectedDeck.length !== 8} className={`px-8 py-3 font-bold rounded-lg transition-all ${selectedDeck.length === 8 ? 'bg-gradient-to-r from-green-500 to-green-600 text-white hover:shadow-lg hover:scale-105 cursor-pointer' : 'bg-gray-600 text-gray-400 cursor-not-allowed opacity-50'}`}>Start Battle</button>
        </div>
      </div>
    )
  }

  if (screen === 'battle') {
    if (gameStateRef.current.gameOver) {
      const gs = gameStateRef.current
      const towers = towerStateRef.current
      const playerTowerHp = Object.values(towers.player).reduce((sum, t) => sum + t.hp, 0)
      const enemyTowerHp = Object.values(towers.enemy).reduce((sum, t) => sum + t.hp, 0)
      const actualWinner = enemyTowerHp < playerTowerHp ? 'player' : enemyTowerHp > playerTowerHp ? 'enemy' : 'tie'

      return (
        <div className="flex flex-col items-center justify-center min-h-screen text-white p-4">
          <div className={`text-5xl font-bold mb-4 victory-popup ${actualWinner === 'player' ? 'text-green-400' : actualWinner === 'tie' ? 'text-yellow-400' : 'text-red-400'}`}>
            {actualWinner === 'player' ? victoryMessages[Math.floor(Math.random() * victoryMessages.length)] : actualWinner === 'tie' ? '⚔️ Tied Battle!' : defeatMessages[Math.floor(Math.random() * defeatMessages.length)]}
          </div>
          <div className="text-2xl mb-6">Your Towers: {Math.max(0, Math.floor(playerTowerHp))} HP<br />Enemy Towers: {Math.max(0, Math.floor(enemyTowerHp))} HP</div>
          <button onClick={() => setScreen('menu')} className="px-8 py-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-bold text-lg rounded-lg hover:shadow-lg hover:scale-105 transition-all">Play Again</button>
        </div>
      )
    }

    return (
      <div className="flex flex-col items-center justify-center min-h-screen text-white p-4">
        {renderUI()}
      </div>
    )
  }

  return null
}

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(<ClashRoyaleGame />);
  </script>
</body>
</html>
